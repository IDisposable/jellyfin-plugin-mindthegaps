<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <RootNamespace>Jellyfin.Plugin.MindTheGaps</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AnalysisMode>AllEnabledByDefault</AnalysisMode>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <!--
    Standalone build: reference the published Jellyfin.* NuGet packages instead of the server
    projects. ExcludeAssets="runtime" keeps the Jellyfin.* assemblies compile-only, so the host's own
    copies load at runtime. TMDbLib is a real runtime dependency (the host does not provide it), so it
    and its Newtonsoft.Json dependency ship alongside the plugin: they are listed in build.yaml's
    artifacts so jprm bundles them into the zip. Versions resolve from the repo-level
    Directory.Packages.props (Jellyfin.* tracks $(JellyfinVersion), the target ABI).
  -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Jellyfin.Controller" ExcludeAssets="runtime" />
    <PackageReference Include="Jellyfin.Model" ExcludeAssets="runtime" />
    <PackageReference Include="Jellyfin.Common" ExcludeAssets="runtime" />
    <PackageReference Include="TMDbLib" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Web\mindthegaps.html" />
    <EmbeddedResource Include="Web\mindthegaps.html" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Jellyfin.Plugin.MindTheGaps.Tests" />
  </ItemGroup>

</Project>
